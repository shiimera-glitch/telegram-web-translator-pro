{
  "env": {
    "browser": true,
    "es2020": true,
    "greasemonkey": true
  },
  "globals": {
    "GM_setValue":              "readonly",
    "GM_getValue":              "readonly",
    "GM_registerMenuCommand":   "readonly",
    "PFX":                     "readonly",
    "DATA_ATTR":                "readonly",
    "VER":                     "readonly",
    "TWTConfig":                "readonly",
    "PUA":                     "readonly",
    "puaStash":                 "writable",
    "detectDir":                "readonly",
    "fixNumericDir":            "readonly",
    "bidiIsolate":              "readonly",
    "getLangDir":               "readonly",
    "getLangLabel":             "readonly",
    "getLangList":              "readonly"
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType":  "script"
  },
  "rules": {
    "no-unused-vars":   ["warn", { "argsIgnorePattern": "^_" }],
    "no-console":       "off",
    "no-undef":         "error",
    "semi":             ["warn", "always"],
    "prefer-const":     "warn",
    "no-var":           "error",
    "eqeqeq":          ["warn", "always"],
    "curly":            "off"
  }
}
