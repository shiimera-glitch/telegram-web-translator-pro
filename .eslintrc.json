{
  "env": {
    "browser": true,
    "es2020": true,
    "greasemonkey": true
  },
  "globals": {
    "GM_setValue":          "readonly",
    "GM_getValue":          "readonly",
    "GM_registerMenuCommand": "readonly"
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType":  "script"
  },
  "rules": {
    "no-unused-vars":    ["warn", { "argsIgnorePattern": "^_" }],
    "no-console":        "off",
    "no-undef":          "error",
    "semi":              ["warn", "always"],
    "prefer-const":      "warn",
    "no-var":            "error",
    "eqeqeq":            ["warn", "always"],
    "curly":             "off"
  }
}
